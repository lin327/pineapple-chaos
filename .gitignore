# ==============================================================================
# PINEAPPLE CHAOS PLATFORM - 国内云定制版 .gitignore
# 防护目标: 腾讯云[备案入口] | 京东云[混沌控制] | 火山云[监控]
# 海外节点: AWS东京 | Azure韩国
# ==============================================================================

# === 0. 绝对禁区 - 国内云厂商凭证 (按厂商分类) ===

# 【腾讯云】Tencent Cloud - 境内入口节点
.tencent/
tccli/
~/.tccli/
*.tccli.conf
tccli.conf
credential.ini
SecretId.txt
SecretKey.txt
*secret_id*
*secret_key*
# 腾讯云CAM凭证（特别注意：腾讯云的SecretKey泄露后无法撤销，必须重新生成）
*.tencentcloudapi.com.key
qcloudcli/

# 【京东云】JD Cloud - 混沌控制节点
.jdcloud/
jdc/
~/.jdc/
jdc-conf/
*.jdc.config
jdc-config.yaml
jdc_credentials
jdcloud_access_key
jdcloud_secret_key
# 京东云有特殊的JDC CLI配置文件

# 【火山云】Volcano Engine - 监控/逃生节点  
.volc/
volcengine/
~/.volc/
volccli/
*.volc.config
volc-credentials
ak.*.txt
sk.*.txt
volc_access_key_id
volc_secret_access_key

# 【通用国内云】阿里云/华为云 (防止误配置)
.aliyun/
aliyuncli/
~/.aliyun/
*.aliyun.config
.aliyuncs/
.huaweicloud/
hcloud/
~/.hcloud/

# 【海外云】保留但严格限制
# AWS (东京节点)
.aws/
aws-credentials*.csv
*accessKeys*.csv
.aws-credentials
# Azure (韩国节点)  
.azure/
azcli-*.txt
*azureAuth.json
.azure-msal-token-cache.json

# === 1. 基础设施即代码 (IaC) - 含5节点IP和密钥 ===
# Terraform (状态文件含明文密码和服务器IP)
*.tfstate
*.tfstate.*
**/.terraform/*
.terraform.lock.hcl
*.tfvars
*.auto.tfvars
!terraform.tfvars.example
# 特别注意：terraform.tfstate会记录腾讯云CVM的root密码！

# Ansible (5台主机清单)
*.retry
inventory/
hosts.ini
host_vars/
group_vars/
!inventory/example/
!group_vars/all.example.yml

# === 2. Docker与容器安全 (Harbor镜像仓库) ===
# 本地数据卷 (含PostgreSQL/Harbor数据)
volumes/
postgres_data/
redis_data/
harbor_data/
docker-registry/

# Docker Compose (含真实内网IP)
docker-compose.override.yml
docker-compose.prod.yml
!docker-compose.yml
!docker-compose.example.yml

# 容器镜像导出
*.tar
*.tar.gz
container-images/

# === 3. 应用配置与密钥 ===
# 环境变量 (所有变体)
.env
.env.*
.env.local
.env.production
!.env.example

# 配置文件
config.yaml
config.json
secrets.yaml
!config.yaml.example

# 证书与SSH密钥 (5台服务器的)
*.pem
*.key
id_rsa*
id_ed25519*
known_hosts
.ssh/
*.pub


# === 4. 备案与合规敏感信息 (中国特色) ===
# 备案信息 (防止爬虫)
icp.txt
beian.txt
*.备案
备案号.txt

# 域名实名认证 (腾讯云要求)
实名认证/
domain-realname-auth/
real-name-verify/

# === 5. 数据库与日志 ===
*.dump
*.backup
*.log
logs/
prometheus/data/
*.pcap  # 抓包文件含敏感流量

# === 6. 混沌工程敏感数据 ===
chaos-reports/
experiments/logs/
fault-injection.log

# === 7. Python/Node开发环境 ===
__pycache__/
*.py[cod]
.venv/
venv/
node_modules/
dist/

# === 8. IDE与系统文件 ===
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# ==============================================================================
# 例外规则 - 显式允许示例文件
# ==============================================================================
!.env.example
!config.yaml.example
!docker-compose.example.yml
!README.md
!LICENSE
