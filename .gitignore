# ==============================================================================
# PINEAPPLE CHAOS PLATFORM - 终极安全版 .gitignore
# 防护目标: 腾讯云(备案) | Azure(API网关) | AWS(数据) | 京东云(混沌) | 火山云(监控)
# 特殊配置: SSH端口37291 | 双备案域名 | 跨国混合云
# ==============================================================================

# === 0. 绝对禁区 - 服务器真实IP（脱敏核心）===
# 所有节点公网IP（永不提交）
*_ip.txt
*_ip_list.txt
hosts.ini
inventory/
ansible.cfg
.terraform.tfvars

# 占位符提醒（提交前检查）
# 正确的: [腾讯云] [Azure] [AWS] [京东云] [火山云]
# 错误的: 49.235.x.x 20.196.x.x 18.182.x.x 36.151.x.x 115.190.x.x

# === 1. SSH与远程连接（端口37291）===
# 所有SSH密钥（无论哪个节点）
*.pem
*.key
*.pub
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
known_hosts
authorized_keys
*.ppk
.ssh/
ssh_config

# 特殊端口配置（37291为非标准SSH端口）
*.port37291.config
ssh_37291.conf

# === 2. 国内云厂商凭证（按厂商分类）===

# 【腾讯云】备案入口节点（pineapple-user.site）
.tencent/
tccli/
~/.tccli/
*.tccli.conf
tccli.conf
credential.ini
SecretId.txt
SecretKey.txt
*secret_id*
*secret_key*
*.tencentcloudapi.com.key
qcloudcli/

# 【京东云】混沌控制节点（pine-server.store）
.jdcloud/
jdc/
~/.jdc/
jdc-conf/
*.jdc.config
jdc-config.yaml
jdc_credentials
jdcloud_access_key
jdcloud_secret_key

# 【火山云】监控/逃生节点
.volc/
volcengine/
~/.volc/
volccli/
*.volc.config
volc-credentials
ak.*.txt
sk.*.txt
volc_access_key_id
volc_secret_access_key

# 【通用国内云】阿里云/华为云（防止误配置）
.aliyun/
aliyuncli/
~/.aliyun/
*.aliyun.config
.aliyuncs/
.huaweicloud/
hcloud/
~/.hcloud/

# === 3. 海外云厂商凭证 ===

# 【AWS】东京节点（PostgreSQL+Harbor）
.aws/
aws-credentials*.csv
*accessKeys*.csv
.aws-credentials
.aws/config
.aws/credentials

# 【Azure】韩国节点（FastAPI网关）
.azure/
azcli-*.txt
*azureAuth.json
.azure-msal-token-cache.json

# === 4. 基础设施即代码 (IaC) - 含5节点配置 ===

# Terraform（状态文件含服务器IP）
*.tfstate
*.tfstate.*
**/.terraform/*
.terraform.lock.hcl
*.tfvars
*.auto.tfvars
!terraform.tfvars.example
terraform.tfplan
crash.log
crash.*.log
override.tf
*_override.tf
.terraformrc
terraform.rc

# Pulumi
Pulumi.*.yaml
!Pulumi.example.yaml

# Ansible（5台主机清单）
*.retry
inventory/
host_vars/
group_vars/
